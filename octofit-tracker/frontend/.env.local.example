# GitHub Codespaces Environment Configuration
# This file contains example environment variables for the Octofit Tracker frontend
# 
# Copy this file to .env.local and update the values with your actual Codespace name
# The values in .env.local will be loaded automatically by Vite during development

# GitHub Codespace Name
# This is required for API communication with the backend
# Get your Codespace name from the GitHub Codespaces dashboard or the CODESPACE_NAME environment variable
# Format: lowercase with hyphens (e.g., 'my-codespace-name')
VITE_CODESPACE_NAME=my-codespace-name
